{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Basic user information and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "settings": {
          "type": "object",
          "properties": {
            "theme": { "type": "string", "enum": ["light", "dark"] },
            "focusMode": { "type": "boolean" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "UserStats": {
      "title": "User Statistics",
      "description": "Aggregate statistics for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "topWpm": { "type": "number" },
        "avgWpm": { "type": "number" },
        "avgAccuracy": { "type": "number" },
        "totalSessions": { "type": "integer" },
        "totalPracticeTime": { "type": "integer" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    },
    "TypingSession": {
      "title": "Typing Session",
      "description": "Records a single typing practice or game session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mode": { "type": "string", "enum": ["learning", "game"] },
        "wpm": { "type": "number" },
        "accuracy": { "type": "number" },
        "errorCount": { "type": "integer" },
        "duration": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mode", "wpm", "accuracy", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profiles"
    },
    "stats/{userId}": {
      "schema": "UserStats",
      "description": "Aggregated stats per user"
    },
    "sessions/{sessionId}": {
      "schema": "TypingSession",
      "description": "Individual session history"
    }
  }
}
